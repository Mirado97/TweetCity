PORT=3001
# Set to true to skip tweet verification (for testing / restricted accounts)
SKIP_TWEET_VERIFY=false
FRONTEND_URL=http://localhost:3000

# Twitter scraper (Twikit)
TWITTER_PROVIDER=apify
TWIKIT_USERNAME=your_twitter_username
TWIKIT_EMAIL=your_twitter_email
TWIKIT_PASSWORD=your_twitter_password
TWIKIT_PROXY=http://user:pass@host:port

# Apify (two keys for rotation)
APIFY_API_TOKEN_1=your_first_apify_key
APIFY_API_TOKEN_2=your_second_apify_key
# Twitter cookie for search mode (auth_token=XXX; ct0=YYY) — from browser DevTools
TWITTER_COOKIE=

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.vibecode-claude.online/v1

# Pinata IPFS
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Mantle oracle wallet
ORACLE_PRIVATE_KEY=your_oracle_wallet_private_key
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
CONTRACT_ADDRESS=
